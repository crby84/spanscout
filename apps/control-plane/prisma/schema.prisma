generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apiKeys     ApiKey[]
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String
  prefix     String
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}